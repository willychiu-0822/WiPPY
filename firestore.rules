rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── V1: User data (habit scheduler) ──────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /foundations/{foundationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /wishes/{wishId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /slots/{slotId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /records/{recordId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── V2: Groups ────────────────────────────────────────────────────────────
    // Backend (service account) writes via Admin SDK — bypasses these rules.
    // Frontend reads are auth-protected by userId field match.
    match /groups/{groupId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Backend only

      match /recentMessages/{messageId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/groups/$(groupId)).data.userId == request.auth.uid;
        allow write: if false; // Backend only
      }
    }

    // ── V2: Activities ────────────────────────────────────────────────────────
    match /activities/{activityId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;

      match /activityMessages/{msgId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/activities/$(activityId)).data.userId == request.auth.uid;
      }
      match /captureRules/{ruleId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/activities/$(activityId)).data.userId == request.auth.uid;
      }
    }

    // ── V2: Activity Knowledge ────────────────────────────────────────────────
    match /activityKnowledge/{knowledgeId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ── V2: Agent Sessions ────────────────────────────────────────────────────
    match /agentSessions/{sessionId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ── V2: Captured messages ─────────────────────────────────────────────────
    match /capturedMessages/{msgId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Backend only
    }

    // ── V2: Send logs ─────────────────────────────────────────────────────────
    match /sendLogs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Backend only
    }

    // ── Harness: HarnessRun (frontend subscribes via onSnapshot) ─────────────
    match /harnessRuns/{runId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Backend only
    }

    // ── Harness: Rate limits (backend only) ───────────────────────────────────
    match /rateLimits/{userId} {
      allow read, write: if false; // Backend only
    }

    // ── V1: LINE link tokens ──────────────────────────────────────────────────
    match /lineLinks/{token} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, delete: if request.auth != null;
    }
  }
}
