# Non-secret production deployment target for WiPPY.
# GitHub Actions reads this file before deploying.

GCP_PROJECT_ID=wippy-mvp
GCP_PROJECT_NUMBER=427895539129
GCP_REGION=asia-east1

CLOUD_RUN_SERVICE=wippy-backend
CLOUD_RUN_URL=https://wippy-backend-ts2nxgrpfa-de.a.run.app

FIREBASE_PROJECT_ID=wippy-mvp
FIREBASE_HOSTING_URL=https://wippy-mvp.web.app
FIREBASE_HOSTING_PUBLIC=frontend/dist
FIRESTORE_RULES=firestore.rules
FIRESTORE_INDEXES=firestore.indexes.json

VITE_FIREBASE_PROJECT_ID=wippy-mvp
VITE_FIREBASE_AUTH_DOMAIN=wippy-mvp.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=wippy-mvp.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=427895539129
VITE_FIREBASE_APP_ID=1:427895539129:web:cac964fbda3640f8c4e268
LIFF_CHANNEL_ID=2010457997
LIFF_ID=2010457997-AsUbpde2
VITE_LIFF_ID=2010457997-AsUbpde2

# Empty means frontend calls /api on Firebase Hosting, then firebase.json rewrites to Cloud Run.
VITE_API_BASE_URL=

LIFF_PATH=/liff/water
LIFF_DEPLOY_NOTIFY_GROUP_ID=C140df0374a3ba2a5864bcff0cbf8befd

# Stable fallback group for the water tracker. liff.getContext().groupId is
# unreliable (it can return an ephemeral value that changes per launch), so the
# backend resolves any request without a valid LINE group id to this group.
# Keep in sync with the shared group above until cross-group storage lands.
WATER_DEFAULT_GROUP_ID=C140df0374a3ba2a5864bcff0cbf8befd
