PORT=8080
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
FIREBASE_PROJECT_ID=your-firebase-project-id
INTERNAL_HARNESS_SECRET=generate_with_openssl_rand_hex_32

# Pick one LLM provider:
# - ollama
# - openai_compatible / openai / anthropic / nvidia
# - vertex_ai
# - gemini
LLM_PROVIDER=ollama

# Ollama defaults
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1

# OpenAI-compatible providers also require:
# LLM_API_KEY=your_api_key

# Vertex AI requires:
# GCP_PROJECT_ID=your_gcp_project_id
# GCP_LOCATION=asia-east1

# Cloud Tasks (optional, omit to run in sync/dev mode):
# CLOUD_TASKS_QUEUE_NAME=your_queue_name
# CLOUD_TASKS_LOCATION=asia-east1
# CLOUD_TASKS_SERVICE_URL=https://your-cloud-run-url
